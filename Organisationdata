function buildDots(){
  const dl=document.getElementById("dl"); dl.innerHTML="";
  const vIds=new Set(vis().map(o=>o.id));
  ORGS.forEach(o=>{
    o.regions.forEach((r,ri)=>{
      const b=RC[r]; if(!b)return;
      const d=document.createElement("div");
      d.className="dot "+(vIds.has(o.id)?"lit":"dim");
      d.style.cssText=`left:${(b.x+jit(o.id,ri,0)*b.sx)/5.2}%;top:${(b.y+jit(o.id,ri,1)*b.sy)/6.6}%;width:8px;height:8px;background:${CC[o.cluster]};`;
      d.onclick=()=>openDrawer(o);
      dl.appendChild(d);
    });
  });
}

function vis(){
  return ORGS.filter(o=>AT.has(o.tier) && AC.has(o.cluster) && (AR==="all" || o.regions.includes(AR)) && (SQ==="" || o.full.toLowerCase().includes(SQ.toLowerCase())));
}

function openDrawer(o){
  document.getElementById("drName").textContent=o.full;
  document.getElementById("drGrid").innerHTML=`<div class="dbox">Tier: ${o.tier}</div><div class="dbox">Cluster: ${o.cluster}</div><div class="dbox" style="grid-column:span 2">${o.notes}</div>`;
  document.getElementById("drRegs").innerHTML=o.regions.map(r=>`<span class="dreg">${r}</span>`).join("");
  document.getElementById("drawer").classList.add("open");
}

function closeDrawer(){document.getElementById("drawer").classList.remove("open");}

function update(){
  buildDots();
  const v=vis();
  document.getElementById("rpN").textContent=v.length;
  const ol=document.getElementById("orgList"); ol.innerHTML=v.map(o=>`<div class="oi" onclick='openDrawer(${JSON.stringify(o)})'>${o.full}</div>`).join("");
}

document.querySelectorAll("[data-region]").forEach(c=>c.onclick=()=>{AR=c.dataset.region; update();});
document.getElementById("search").oninput=(e)=>{SQ=e.target.value; update();};

buildDots(); update();
</script>
</body>
</html>

